<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AffairList.Views.AffairsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:AffairList.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24,24,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="My Affairs" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <CommandBar DefaultLabelPosition="Right" Background="Transparent" HorizontalAlignment="Right">
                <AppBarButton Icon="Undo" Label="Undo" Command="{x:Bind ViewModel.UndoCommand}"/>
                <AppBarButton Icon="Redo" Label="Redo" Command="{x:Bind ViewModel.RedoCommand}"/>
            </CommandBar>
        </Grid>

        <ListView 
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Affairs, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedAffair, Mode=TwoWay}"
            SelectionMode="Single">

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:AffairItem">
                    <Grid Padding="0,12" ColumnDefinitions="Auto, *">
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Toggle Priority" Icon="Favorite" Click="TogglePriority_Click"/>
                                <MenuFlyoutItem Text="Rename" Icon="Rename" Click="Rename_Click"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Delete" Icon="Delete" Click="Delete_Click" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </MenuFlyout>
                        </Grid.ContextFlyout>

                        <FontIcon Grid.Column="0" 
                                  Glyph="&#xE734;" 
                                  Visibility="{x:Bind IsPriority, Mode=OneWay}"
                                  Margin="0,0,12,0"
                                  FontSize="16"
                                  VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" 
                                   Text="{x:Bind DisplayText, Mode=OneWay}" 
                                   FontSize="16" 
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,20,0,24" ColumnSpacing="12">
            <TextBox 
                Grid.Column="0" 
                PlaceholderText="Type a new affair and press Enter..." 
                Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                KeyDown="InputTextBox_KeyDown"
                VerticalAlignment="Stretch"/>

            <Button 
                Grid.Column="1" 
                Content="Add Affair" 
                Command="{x:Bind ViewModel.AddAffairCommand}" 
                Style="{StaticResource AccentButtonStyle}"
                Height="32"/>
        </Grid>

        <ContentDialog x:Name="RenameDialog"
                       Title="Rename Affair"
                       PrimaryButtonText="Save"
                       CloseButtonText="Cancel"
                       DefaultButton="Primary">
            <TextBox x:Name="RenameTextBox" PlaceholderText="New name..." Width="300"/>
        </ContentDialog>
    </Grid>
</Page>