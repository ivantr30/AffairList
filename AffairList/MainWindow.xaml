<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AffairList.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:AffairList.Views">

    <Grid>
        <NavigationView x:Name="NavView" SelectionChanged="NavView_SelectionChanged" IsSettingsVisible="True">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Affairs" Tag="AffairsPage" Icon="List"/>
                <NavigationViewItem Content="Profiles" Tag="ProfilesPage" Icon="Contact"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>